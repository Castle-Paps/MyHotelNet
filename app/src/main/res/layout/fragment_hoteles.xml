<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7F6F3">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="10dp"
        android:elevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hoteles"
                    android:textSize="22sp"
                    android:textColor="#1A1A1A"
                    android:fontFamily="@font/poppins_bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lima · 2 adultos · 2 noches"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:fontFamily="@font/poppins_light"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/ivBuscar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_filter"
                android:padding="6dp"
                android:tint="#1A7A6E"
                android:background="@drawable/bg_filter_btn"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/searchBar"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_search"
            android:paddingHorizontal="14dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search"
                android:tint="#BBBBBB"
                android:layout_marginEnd="10dp"/>

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/tietBuscar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Destino, hotel o zona..."
                android:textSize="13sp"
                android:textColorHint="#BBBBBB"
                android:background="@null"
                android:inputType="text"
                android:fontFamily="@font/poppins_light"/>
        </LinearLayout>
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingVertical="10dp"
        android:background="#FFFFFF">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <TextView
                android:id="@+id/chipTodos"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Todos"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="@drawable/bg_chip_active"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/poppins_medium"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Playa"
                android:textSize="12sp"
                android:textColor="#0F6E56"
                android:gravity="center"
                android:background="@drawable/bg_chip_inactive"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/poppins_medium"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Ciudad"
                android:textSize="12sp"
                android:textColor="#0F6E56"
                android:gravity="center"
                android:background="@drawable/bg_chip_inactive"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/poppins_medium"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Montaña"
                android:textSize="12sp"
                android:textColor="#0F6E56"
                android:gravity="center"
                android:background="@drawable/bg_chip_inactive"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/poppins_medium"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Spa"
                android:textSize="12sp"
                android:textColor="#0F6E56"
                android:gravity="center"
                android:background="@drawable/bg_chip_inactive"
                android:paddingHorizontal="16dp"
                android:fontFamily="@font/poppins_medium"/>
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">
        <LinearLayout
            android:id="@+id/llHoteles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp"/>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
