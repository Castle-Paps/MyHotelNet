<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7F6F3">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:elevation="2dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hotel"
                android:textSize="20sp"
                android:textColor="#1A1A1A"
                android:fontFamily="@font/poppins_bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Net"
                android:textSize="20sp"
                android:textColor="#1A7A6E"
                android:fontFamily="@font/poppins_bold"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnPublicarNoticia"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="+ Publicar"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A7A6E"
            android:visibility="gone"
            android:fontFamily="@font/poppins_semi_bold"
            app:cornerRadius="10dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/cardDestacado"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:background="#1A7A6E"
        android:orientation="vertical"
        android:gravity="bottom"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DESTACADO"
            android:textSize="9sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_pill_white"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="@font/poppins_bold"/>

        <TextView
            android:id="@+id/tvTituloDestacado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="3dp"
            android:fontFamily="@font/poppins_bold"/>

        <TextView
            android:id="@+id/tvSubtituloDestacado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#AAFFEE"
            android:fontFamily="@font/poppins_light"/>
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="#FFFFFF"
        android:paddingVertical="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Todo"
                android:textSize="12sp"
                android:textColor="#1A7A6E"
                android:gravity="center"
                android:background="@drawable/bg_filter_active"
                android:paddingHorizontal="14dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/poppins_medium"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Aperturas"
                android:textSize="12sp"
                android:textColor="#888888"
                android:gravity="center"
                android:background="@drawable/bg_filter_inactive"
                android:paddingHorizontal="14dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/poppins_medium"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Ofertas"
                android:textSize="12sp"
                android:textColor="#888888"
                android:gravity="center"
                android:background="@drawable/bg_filter_inactive"
                android:paddingHorizontal="14dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/poppins_medium"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Eventos"
                android:textSize="12sp"
                android:textColor="#888888"
                android:gravity="center"
                android:background="@drawable/bg_filter_inactive"
                android:paddingHorizontal="14dp"
                android:fontFamily="@font/poppins_medium"/>
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:id="@+id/llNoticias"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp"/>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
